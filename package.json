{
  "name": "chrome-agent-mcp",
  "version": "1.0.0",
  "description": "MCP server for Chrome — multi-tab parallel control, DevTools inspection, browser management",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "chrome-agent-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage"
  },
  "keywords": [
    "mcp",
    "chrome",
    "browser",
    "automation",
    "claude",
    "ai",
    "devtools",
    "playwright"
  ],
  "author": "Otavio Senne <otavio.senne@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/otaviosenne/chrome-agent-mcp"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "chrome-remote-interface": "^0.33.0"
  },
  "devDependencies": {
    "@types/chrome-remote-interface": "^0.33.0",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.0"
  }
}
